---
import Layout from '@/layouts/Layout.astro';
import { getContactPage } from '@/lib/sanity';
import { fallbackContact } from '@/lib/fallback';

let data = fallbackContact;
try {
  const fetched = await getContactPage();
  if (fetched) data = { ...fallbackContact, ...fetched };
} catch (_) {}
---

<Layout title="Contact Us" description={data.subheading}>

  <!-- ── PAGE HEADER ──────────────────────────────────────────── -->
  <section class="pt-36 pb-16 px-6 lg:px-8 bg-brand-gray border-b border-gray-200">
    <div class="max-w-7xl mx-auto">
      <span class="text-xs font-semibold tracking-widest uppercase text-brand-gray-mid">Contact Us</span>
      <h1 class="text-4xl md:text-6xl font-black tracking-tight text-brand-black mt-3 mb-6 max-w-2xl">
        {data.heading}
      </h1>
      <p class="text-lg text-brand-gray-mid max-w-2xl leading-relaxed">{data.subheading}</p>
    </div>
  </section>

  <!-- ── CONTACT CONTENT ──────────────────────────────────────── -->
  <section class="py-24 px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Contact form -->
      <div>
        <h2 class="text-xl font-bold text-brand-black mb-8">Send us a message</h2>
        <form
          id="contact-form"
          class="space-y-6"
          novalidate
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-xs font-semibold uppercase tracking-widest text-brand-gray-mid mb-2">
                Full Name *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full border border-gray-200 px-4 py-3 text-sm text-brand-black placeholder-gray-300 focus:outline-none focus:border-brand-black transition-colors"
                placeholder="John Doe"
              />
            </div>
            <div>
              <label for="email" class="block text-xs font-semibold uppercase tracking-widest text-brand-gray-mid mb-2">
                Email Address *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-gray-200 px-4 py-3 text-sm text-brand-black placeholder-gray-300 focus:outline-none focus:border-brand-black transition-colors"
                placeholder="you@company.com"
              />
            </div>
          </div>

          <div>
            <label for="company" class="block text-xs font-semibold uppercase tracking-widest text-brand-gray-mid mb-2">
              Company
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full border border-gray-200 px-4 py-3 text-sm text-brand-black placeholder-gray-300 focus:outline-none focus:border-brand-black transition-colors"
              placeholder="Your Company Ltd."
            />
          </div>

          <div>
            <label for="service" class="block text-xs font-semibold uppercase tracking-widest text-brand-gray-mid mb-2">
              Service Interested In
            </label>
            <select
              id="service"
              name="service"
              class="w-full border border-gray-200 px-4 py-3 text-sm text-brand-black focus:outline-none focus:border-brand-black transition-colors bg-white"
            >
              <option value="">Select a service...</option>
              <option>Custom Software Development</option>
              <option>SaaS Product Development</option>
              <option>API Development & Integrations</option>
              <option>Digital Transformation</option>
              <option>Other / Not Sure Yet</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-xs font-semibold uppercase tracking-widest text-brand-gray-mid mb-2">
              Message *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full border border-gray-200 px-4 py-3 text-sm text-brand-black placeholder-gray-300 focus:outline-none focus:border-brand-black transition-colors resize-none"
              placeholder="Tell us about your project..."
            ></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full py-4 bg-brand-black text-white font-semibold text-sm tracking-wide hover:bg-brand-gray-dark transition-colors duration-200 disabled:opacity-50"
          >
            Send Message
          </button>

          <p id="form-status" class="text-sm text-center hidden"></p>
        </form>
      </div>

      <!-- Contact details -->
      <div class="lg:pl-8">
        <h2 class="text-xl font-bold text-brand-black mb-8">Contact Details</h2>
        <div class="space-y-8">

          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 bg-brand-gray flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-brand-gray-mid mb-1">Email</p>
              <a href={`mailto:${data.email}`} class="text-brand-black font-medium hover:underline">{data.email}</a>
            </div>
          </div>

          {data.phone && (
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 bg-brand-gray flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-brand-gray-mid mb-1">Phone</p>
                <a href={`tel:${data.phone}`} class="text-brand-black font-medium hover:underline">{data.phone}</a>
              </div>
            </div>
          )}

          {data.address && (
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 bg-brand-gray flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-brand-gray-mid mb-1">Address</p>
                <p class="text-brand-black font-medium whitespace-pre-line">{data.address}</p>
              </div>
            </div>
          )}

          <!-- Response time note -->
          <div class="mt-10 p-6 bg-brand-gray border-l-4 border-brand-black">
            <p class="text-sm font-semibold text-brand-black mb-1">We respond within 24 hours</p>
            <p class="text-sm text-brand-gray-mid">
              For urgent enquiries, please email us directly and mention it in the subject line.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending...';

    // Placeholder: swap this for your form backend (Formspree, Resend, etc.)
    await new Promise((r) => setTimeout(r, 1000));

    status.textContent = "Thanks! We'll be in touch within 24 hours.";
    status.className = 'text-sm text-center text-green-600';
    status.classList.remove('hidden');
    form.reset();
    btn.textContent = 'Send Message';
    btn.disabled = false;
  });
</script>
