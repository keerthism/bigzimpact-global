---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Home" description="Big Impact Global — Fintech · Edtech · Consulting. Building impact at scale.">

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section class="hero">
    <h1 class="hero-title">
      <span class="line"><span>BiG</span></span>
      <span class="line"><span><em>Real</em></span></span>
      <span class="line"><span>Impact.</span></span>
    </h1>
    <div class="hero-bottom">
      <p class="hero-lede">One company, three engines. Synchronyzing Zero-MDR payment networks, AI powered global mobility platforms and B2B/B2C pipeline building for sales.</p>
    </div>
  </section>

  <!-- ── STATS ─────────────────────────────────────────────── -->
  <section class="stats">
    <div class="stat">
      <div class="num" data-count="17" data-suffix="+">0</div>
      <div class="lbl">Merchants live</div>
    </div>
    <div class="stat">
      <div class="num" data-count="3" data-suffix=" engines">0</div>
      <div class="lbl">Business lines</div>
    </div>
    <div class="stat">
      <div class="num" data-count="0" data-prefix="₹" data-suffix=" MDR">0</div>
      <div class="lbl">On collections</div>
    </div>
    <div class="stat">
      <div class="num" data-count="100" data-suffix="k target">0</div>
      <div class="lbl">Users by 2026</div>
    </div>
  </section>

  <!-- ── WHY ───────────────────────────────────────────────── -->
  <section class="section why" id="why">
    <div class="sec-head reveal">
      <span class="sec-num">[ 01 ]</span>
      <h2 class="sec-title">Why BiG</h2>
    </div>
    <div class="why-grid">
      <div class="why-cell reveal">
        <span class="wnum">A / SPEED</span>
        <h3>Ship in months</h3>
        <p>Agile, founder-led execution. Products reach market while others are still planning.</p>
        <div class="bar"></div>
      </div>
      <div class="why-cell reveal reveal-d1">
        <span class="wnum">B / SCALE</span>
        <h3>Unit positive</h3>
        <p>Proven economics from day one. A model engineered to compound, not to burn.</p>
        <div class="bar"></div>
      </div>
      <div class="why-cell reveal reveal-d2">
        <span class="wnum">C / TRUST</span>
        <h3>Built to last</h3>
        <p>Bank partnerships, regulatory readiness, and enterprise-grade security at the core.</p>
        <div class="bar"></div>
      </div>
    </div>
  </section>

  <!-- ── PRODUCTS ──────────────────────────────────────────── -->
  <section class="section" id="products" style="background:var(--paper)">
    <div class="sec-head reveal">
      <span class="sec-num">[ 02 ]</span>
      <h2 class="sec-title">Three engines</h2>
      <span class="sec-meta">SELECT TO EXPLORE</span>
    </div>
    <div class="prod-list">
      <a href="https://ezecollect.in/" target="_blank" rel="noopener noreferrer" class="prod-row reveal" style="text-decoration:none;color:inherit;display:flex;align-items:center;">
        <span class="pnum">01</span>
        <div class="pname">
          Reconciliation
          <span class="pdesc">Zero-MDR UPI collections for merchants &amp; distributors.</span>
        </div>
        <div class="pright">
          <span class="pstatus live">Live</span>
          <span class="parr">↗</span>
        </div>
      </a>
      <div class="prod-row reveal reveal-d1">
        <span class="pnum">02</span>
        <div class="pname">
          Learning
          <span class="pdesc">AI powered adaptive platform engeering global student mobility</span>
        </div>
        <div class="pright">
          <span class="pstatus">Q1 2026</span>
          <span class="parr">↗</span>
        </div>
      </div>
      <div class="prod-row reveal reveal-d2">
        <span class="pnum">03</span>
        <div class="pname">
          Consulting
          <span class="pdesc">Delivering Cloud Transformation Opportunity &amp; qualified prospect engagement</span>
        </div>
        <div class="pright">
          <span class="pstatus live">Live</span>
          <span class="parr">↗</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PORTFOLIO ─────────────────────────────────────────── -->
  <section class="section work" id="work">
    <div class="sec-head reveal">
      <span class="sec-num" style="color:var(--berry)">[ 03 ]</span>
      <h2 class="sec-title">In motion</h2>
      <span class="sec-meta" style="opacity:0.6">SELECTED WORK</span>
    </div>
    <div class="work-grid">
      <div class="work-card span7 reveal">
        <span class="wc-idx">CASE / 01</span>
        <h4>Scaling distribution with strategic B2B &amp; B2C.</h4>
        <div class="wc-line"></div>
        <p>Embedding payments into supply chains — turning onboarding friction into a growth engine.</p>
      </div>
      <div class="work-card span5 reveal reveal-d1">
        <span class="wc-idx">CASE / 02</span>
        <h4>Learning</h4>
        <div class="wc-line"></div>
        <p>Engineering seamless cross border pathways.</p>
      </div>
      <div class="work-card span4 reveal">
        <span class="wc-idx">CASE / 03</span>
        <h4>Path to profitability</h4>
        <div class="wc-line"></div>
        <p>Monthly-positive economics, mapped and tracking.</p>
      </div>
      <div class="work-card span8 reveal reveal-d1">
        <span class="wc-idx">CASE / 04</span>
        <h4>Audience Generation</h4>
        <div class="wc-line"></div>
        <p>Drive high quality audience engagement across webinar, survey & events.</p>
      </div>
    </div>
  </section>

  <!-- ── TECH STACK ─────────────────────────────────────────── -->
  <section class="section" id="tech" style="background:var(--white);border-top:1px solid var(--line)">
    <div class="sec-head reveal">
      <span class="sec-num">[ 04 ]</span>
      <h2 class="sec-title">The stack</h2>
      <span class="sec-meta">ENGINEERED TO SCALE</span>
    </div>
    <div class="tech-grid reveal">
      <div class="tech-cell"><span class="tc-num">01</span><span class="tc-name">Cloud<br />Transormation</span></div>
      <div class="tech-cell"><span class="tc-num">02</span><span class="tc-name">AI<br />First</span></div>
      <div class="tech-cell"><span class="tc-num">03</span><span class="tc-name">Enterprise<br />Security</span></div>
      <div class="tech-cell"><span class="tc-num">04</span><span class="tc-name">Auto<br />DevOps</span></div>
      <div class="tech-cell"><span class="tc-num">05</span><span class="tc-name">Mobile<br />First</span></div>
      <div class="tech-cell"><span class="tc-num">06</span><span class="tc-name">Open<br />APIs</span></div>
    </div>
  </section>

  <!-- ── INVESTOR CTA ───────────────────────────────────────── -->
  <section class="cta" id="invest">
    <div class="cta-inner">
      <div class="eyebrow">For investors · partners · media</div>
      <h2>Let's build the impact together.</h2>
      <p>We're scaling three engines under one brand. If you back ambitious operators, we should talk.</p>
      <button class="btn-light" id="open-partner-modal-cta">SCHEDULE A CALL <span>→</span></button>
    </div>
    <div class="cta-watermark" data-parallax="0.1">BiG</div>
  </section>

</Layout>

<script>
  // Grid overlay on scroll
  let gridShown = false;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 200 && !gridShown) {
      document.body.classList.add('grid-on');
      gridShown = true;
    } else if (window.scrollY <= 200 && gridShown) {
      document.body.classList.remove('grid-on');
      gridShown = false;
    }
  }, { passive: true });

  // Scroll reveal
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // Animated counters
  function animateCount(el: Element) {
    const target = parseFloat((el as HTMLElement).dataset.count!);
    const prefix = (el as HTMLElement).dataset.prefix ?? '';
    const suffix = (el as HTMLElement).dataset.suffix ?? '';
    const dur = 1400;
    const start = performance.now();
    function tick(now: number) {
      const p = Math.min((now - start) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      const val = Math.round(target * eased);
      el.innerHTML = prefix + val.toLocaleString() + '<span class="suffix">' + suffix + '</span>';
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const countIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        animateCount(e.target);
        countIO.unobserve(e.target);
      }
    });
  }, { threshold: 0.6 });
  document.querySelectorAll('[data-count]').forEach(el => countIO.observe(el));

  // Magnetic buttons
  document.querySelectorAll<HTMLElement>('.btn-magnet, .btn-light').forEach(btn => {
    btn.addEventListener('mousemove', (e) => {
      const r = btn.getBoundingClientRect();
      const x = e.clientX - r.left - r.width / 2;
      const y = e.clientY - r.top - r.height / 2;
      btn.style.transform = `translate(${x * 0.25}px, ${y * 0.35}px)`;
    });
    btn.addEventListener('mouseleave', () => btn.style.transform = 'translate(0,0)');
  });

  // Parallax
  const parallaxEls = document.querySelectorAll<HTMLElement>('[data-parallax]');
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    parallaxEls.forEach(el => {
      const speed = parseFloat(el.dataset.parallax!);
      el.style.transform = `translateY(${y * speed}px)`;
    });
  }, { passive: true });

  document.getElementById('open-partner-modal-cta')?.addEventListener('click', () => {
    const modal = document.getElementById('partner-modal');
    if (modal) {
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
  });
</script>
