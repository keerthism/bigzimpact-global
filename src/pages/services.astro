---
import Layout from '@/layouts/Layout.astro';
import { getServicesPage } from '@/lib/sanity';
import { fallbackServices } from '@/lib/fallback';

let data = fallbackServices;
try {
  const fetched = await getServicesPage();
  if (fetched) data = { ...fallbackServices, ...fetched };
} catch (_) {}
---

<Layout title="Services" description={data.subheading}>

  <!-- ── PAGE HEADER ──────────────────────────────────────────── -->
  <section class="pt-36 pb-16 px-6 lg:px-8 bg-brand-gray border-b border-gray-200">
    <div class="max-w-7xl mx-auto">
      <span class="text-xs font-semibold tracking-widest uppercase text-brand-gray-mid">What We Do</span>
      <h1 class="text-4xl md:text-6xl font-black tracking-tight text-brand-black mt-3 mb-6 max-w-3xl">
        {data.heading}
      </h1>
      <p class="text-lg text-brand-gray-mid max-w-2xl leading-relaxed">{data.subheading}</p>
    </div>
  </section>

  <!-- ── SERVICES LIST ────────────────────────────────────────── -->
  <section class="py-24 px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto space-y-20">
      {data.services.map((service, i) => (
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-start ${i % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}>
          <!-- Text side -->
          <div class={i % 2 === 1 ? 'lg:col-start-2' : ''}>
            <span class="text-4xl mb-4 block">{service.icon}</span>
            <h2 class="text-2xl md:text-3xl font-black tracking-tight text-brand-black mb-4">
              {service.title}
            </h2>
            <p class="text-brand-gray-mid leading-relaxed mb-8">{service.description}</p>
            <ul class="space-y-3">
              {service.features?.map((f) => (
                <li class="flex items-center gap-3 text-sm text-brand-black">
                  <span class="w-5 h-5 rounded-full bg-brand-black flex items-center justify-center shrink-0">
                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
          <!-- Visual side -->
          <div class={`bg-brand-gray h-64 lg:h-80 flex items-center justify-center ${i % 2 === 1 ? 'lg:col-start-1' : ''}`}>
            <span class="text-7xl opacity-20">{service.icon}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────── -->
  <section class="py-20 px-6 lg:px-8 bg-brand-black">
    <div class="max-w-7xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-5">
        Not sure what you need?
      </h2>
      <p class="text-white/60 mb-8 max-w-lg mx-auto">
        Let's talk through your challenge and find the right approach together.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 bg-white text-brand-black font-semibold text-sm hover:bg-gray-100 transition-colors"
      >
        Schedule a Free Consultation
      </a>
    </div>
  </section>

</Layout>
