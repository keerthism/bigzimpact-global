---
import Layout from '@/layouts/Layout.astro';
import { getAboutPage } from '@/lib/sanity';
import { fallbackAbout } from '@/lib/fallback';

let data = fallbackAbout;
try {
  const fetched = await getAboutPage();
  if (fetched) data = { ...fallbackAbout, ...fetched };
} catch (_) {}
---

<Layout title="About Us" description={data.subheading}>

  <!-- ── PAGE HEADER ──────────────────────────────────────────── -->
  <section class="pt-36 pb-16 px-6 lg:px-8 bg-brand-gray border-b border-gray-200">
    <div class="max-w-7xl mx-auto">
      <span class="text-xs font-semibold tracking-widest uppercase text-brand-gray-mid">About Us</span>
      <h1 class="text-4xl md:text-6xl font-black tracking-tight text-brand-black mt-3 mb-6 max-w-3xl">
        {data.heading}
      </h1>
      <p class="text-lg text-brand-gray-mid max-w-2xl leading-relaxed">{data.subheading}</p>
    </div>
  </section>

  <!-- ── STATS ────────────────────────────────────────────────── -->
  <section class="py-16 px-6 lg:px-8 bg-brand-black">
    <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
      {data.stats.map((s) => (
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-black text-white mb-2">{s.value}</div>
          <div class="text-xs font-medium tracking-widest uppercase text-white/40">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── OUR STORY ─────────────────────────────────────────────── -->
  <section class="py-24 px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-brand-black mb-6">Our Story</h2>
        <p class="text-brand-gray-mid leading-relaxed text-base">{data.story}</p>
      </div>
      <div class="grid grid-cols-1 gap-8">
        <!-- Mission -->
        <div class="border-l-4 border-brand-black pl-6 py-2">
          <h3 class="text-xs font-bold uppercase tracking-widest text-brand-gray-mid mb-3">Mission</h3>
          <p class="text-brand-black font-medium leading-relaxed">{data.mission}</p>
        </div>
        <!-- Vision -->
        <div class="border-l-4 border-gray-300 pl-6 py-2">
          <h3 class="text-xs font-bold uppercase tracking-widest text-brand-gray-mid mb-3">Vision</h3>
          <p class="text-brand-black font-medium leading-relaxed">{data.vision}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TEAM ──────────────────────────────────────────────────── -->
  {data.team && data.team.length > 0 && (
    <section class="py-24 px-6 lg:px-8 bg-brand-gray">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-brand-black mb-14">Our Team</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {data.team.map((member) => (
            <div class="bg-white p-8 border border-gray-100">
              {member.photo && (
                <img
                  src={member.photo}
                  alt={member.name}
                  class="w-16 h-16 rounded-full object-cover mb-5 grayscale"
                />
              )}
              {!member.photo && (
                <div class="w-16 h-16 rounded-full bg-brand-black flex items-center justify-center mb-5">
                  <span class="text-white font-bold text-xl">
                    {member.name.charAt(0)}
                  </span>
                </div>
              )}
              <h3 class="font-bold text-brand-black mb-1">{member.name}</h3>
              <p class="text-xs font-semibold tracking-widest uppercase text-brand-gray-mid mb-4">{member.role}</p>
              {member.bio && <p class="text-sm text-brand-gray-mid leading-relaxed">{member.bio}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── CTA ───────────────────────────────────────────────────── -->
  <section class="py-20 px-6 lg:px-8 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
      <h2 class="text-2xl md:text-3xl font-black tracking-tight text-brand-black max-w-md">
        Want to work with us?
      </h2>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 bg-brand-black text-white font-semibold text-sm hover:bg-brand-gray-dark transition-colors shrink-0"
      >
        Get in Touch
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</Layout>
